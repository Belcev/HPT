{
    "name": "belcev/hpt",
    "description": "mini E-com Api",
    "autoload": {
        "psr-4": {
            "Belcev\\Hpt\\": "src/",
            "App\\": "app/"
        }
    },
    "authors": [
        {
            "name": "Belčev"
        }
    ],
    "require": {
        "slim/slim": "^4.15",
        "slim/psr7": "^1.8",
        "php-di/php-di": "^7.1",
        "guzzlehttp/guzzle": "^7.10",
        "doctrine/dbal": "^4.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3",
        "symplify/easy-coding-standard": "^13.0"
    },
    "scripts": {
        "phpstan": "phpstan analyse",
        "rector-fix": "rector process",
        "rector": "rector process --dry-run",
        "ecs": "ecs check",
        "ecs-fix": "ecs check --fix",
        "check": [
            "@phpstan",
            "@rector",
            "@ecs"
        ]
    }
}
